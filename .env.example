OPENAI_API_KEY=sk-placeholder
NASA_API_KEY=DEMO_KEY
# Default assumes the docker-compose db service (make db-up); override if using a different Postgres instance.
# Host port is 5433 (not the default 5432) to avoid clashing with other local Postgres containers.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nasa_rag
# Comma-separated list of allowed CORS origins. Defaults to the local frontend
# dev origin; set to your deployed Vercel URL(s) in production.
CORS_ORIGINS=http://localhost:3000
